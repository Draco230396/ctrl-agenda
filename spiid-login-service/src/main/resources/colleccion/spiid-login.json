{
  "info": {
    "name": "SPIID LOGIN Service (PRO)",
    "_postman_id": "b2a3c6e4-iam-pro-collection",
    "description": "Colección completa IAM SPIID con login local + Google + JWT + Refresh",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "GET Roles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/catalog/roles"
          }
        }
      ]
    },
    {
      "name": "Auth - Local",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);",
                  "if (data.user?.tenantId) pm.environment.set('tenantId', data.user.tenantId);",
                  "if (data.user?.id) pm.environment.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"roleCodes\": [1]\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "Auth - Google",
      "item": [
        {
          "name": "Google Login (OWNER - create tenant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Google OWNER OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);",
                  "if (data.user?.tenantId) pm.environment.set('tenantId', data.user.tenantId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\",\n  \"role\": \"OWNER\",\n  \"tenantId\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/google"
          }
        },
        {
          "name": "Google Login (CLIENT - join tenant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Google CLIENT OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\",\n  \"role\": \"CLIENT\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/google"
          }
        }
      ]
    },
    {
      "name": "Auth - Session",
      "item": [
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Auth works', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('Tenant exists', () => pm.expect(data.tenantId).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    }
  ]
}